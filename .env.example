# ===== 必填：LLM 网关配置（请替换为真实值）=====
LITELLM_PROXY_API_BASE=https://your-litellm-gateway.example.com
LITELLM_PROXY_API_KEY=your-api-key

# 可选：默认模型
DISCOVERY_ZERO_LLM_MODEL=gpt-5.2

# ===== LLM 请求参数 =====
# 每次请求最大 token 数（0=不限制）
DISCOVERY_ZERO_MAX_OUTPUT_TOKENS=16000
# 截断自动续传：模型输出被截断时自动发送续传请求的最大次数（0=禁用）
DISCOVERY_ZERO_LLM_AUTO_CONTINUE=3
# 单次 LLM 请求超时（秒）
# DISCOVERY_ZERO_LLM_TIMEOUT=300
# 启用流式生成（推荐，避免长生成超时）
# DISCOVERY_ZERO_LLM_STREAMING=true

# ===== MCTS 搜索引擎 =====
DISCOVERY_ZERO_ENABLE_MCTS=1
# 最大迭代次数
# DISCOVERY_ZERO_MCTS_MAX_ITERATIONS=50
# 最大运行时间（秒）
DISCOVERY_ZERO_MCTS_MAX_TIME_SECONDS=21600

# ===== 信念传播 =====
# 后端："gaia_v2"（推荐）| "gaia" | "energy"
# DISCOVERY_ZERO_BP_BACKEND=gaia_v2
# 最大 BP 迭代次数
# DISCOVERY_ZERO_BP_MAX_ITERATIONS=50

# ===== 验证管线 =====
# 启用 ClaimPipeline + SignalAccumulator
# DISCOVERY_ZERO_VERIFICATION_LOOP_ENABLED=true
# 并行验证线程数
# DISCOVERY_ZERO_VERIFICATION_PARALLEL_WORKERS=3
# 启用 Lean 结构化反馈
# DISCOVERY_ZERO_LEAN_FEEDBACK_ENABLED=true

# ===== 完整配置参考 =====
# 所有 DISCOVERY_ZERO_* 配置项及默认值见 src/discovery_zero/config.py
